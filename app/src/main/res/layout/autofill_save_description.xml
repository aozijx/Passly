<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:foreground="@null"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 应用图标：增加点击感 -->
    <ImageView
        android:id="@+id/save_icon"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/autofill_save_icon_description"
        android:scaleType="fitCenter" />

    <!-- 标题：使用更醒目的字体大小和间距 -->
    <TextView
        android:id="@+id/save_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/autofill_save_prompt_title"
        android:textColor="@color/on_primary_container_light"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- 描述：增加行间距，显示更清晰 -->
    <TextView
        android:id="@+id/save_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        android:textColor="@color/on_primary_container_light"
        android:textSize="14sp" />

</LinearLayout>
